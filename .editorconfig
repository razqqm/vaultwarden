root = true

[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8

[*.dart]
indent_style = space
indent_size = 2

[*.{yaml,yml,arb}]
indent_style = space
indent_size = 2

[*.{md,markdown}]
trim_trailing_whitespace = false

[*.{gradle,kts}]
indent_style = space
indent_size = 4

[*.swift]
indent_style = space
indent_size = 4

[Makefile]
indent_style = tab
